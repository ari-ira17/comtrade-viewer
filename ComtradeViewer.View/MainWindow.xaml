<Window x:Class="ComtradeViewer.View.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ComtradeViewer.ViewModel.ViewModels;assembly=ComtradeViewer.ViewModel"
        xmlns:views="clr-namespace:ComtradeViewer.View.Views"
        xmlns:conv="clr-namespace:ComtradeViewer.View.Converters"
        Title="Comtrade Viewer" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    

    <Grid>
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
                <Button Content="Открыть файл .cfg" Command="{Binding OpenFileCommand}" Padding="10,5"/>
                <Button Content="Настройки" Command="{Binding OpenSettingsCommand}" Padding="10,5" Margin="10,0"/>
                <Button Content="Сбросить масштаб" Command="{Binding ResetZoomCommand}" Padding="10,5" Margin="10,0"/>
                <Button Content="Сброс диапазона" Command="{Binding ClearRangeCommand}" Padding="10,5" Margin="10,0"/>
                <TextBlock Text="{Binding StatusText}" Margin="20,0,0,0" 
                           VerticalAlignment="Center" Foreground="DarkGreen" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding FileInfo}" Margin="20,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <ScrollBar DockPanel.Dock="Bottom" 
                       Orientation="Horizontal"
                       Minimum="{Binding ScrollMinimum}"
                       Maximum="{Binding ScrollMaximum}"
                       Value="{Binding ScrollValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       ViewportSize="{Binding ViewportSize}"
                       SmallChange="0.01"
                       LargeChange="{Binding ViewportSize}"
                       Margin="10,0,10,5"/>

            <TabControl ItemsSource="{Binding OpenFiles}" SelectedItem="{Binding SelectedFile}">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                            <Button Content="✕" 
                                    Command="{Binding DataContext.CloseFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" BorderThickness="0" Padding="2,0"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding FilteredChannelPlots}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <views:ChannelPlotControl DataContext="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </DockPanel>

        <Border Background="#DDFFFFE0" BorderBrush="Black" BorderThickness="1" CornerRadius="4"
                Padding="6" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10"
                Visibility="{Binding HasRangeInfo, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding RangeInfoText}" FontWeight="Bold" LineHeight="14"/>
        </Border>
    </Grid>
</Window>
