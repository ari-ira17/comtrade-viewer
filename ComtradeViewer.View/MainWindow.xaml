<Window x:Class="ComtradeViewer.View.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ComtradeViewer.ViewModel.ViewModels;assembly=ComtradeViewer.ViewModel"
        xmlns:views="clr-namespace:ComtradeViewer.View.Views"
        Title="Comtrade Viewer" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
         </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="130"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="8,0,8,0"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#C8C8C8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0E0E0"/>
                                <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#AAA" BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D0D0D0"/>
                                <Setter Property="BorderBrush" Value="#888"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF6666"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#C8C8C8"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6,6,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#AAAAAA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TabItem_PreviewMouseLeftButtonDown"/>
            <EventSetter Event="MouseMove" Handler="TabItem_MouseMove"/>
            <EventSetter Event="Drop" Handler="TabItem_Drop"/>
            <EventSetter Event="DragOver" Handler="TabItem_DragOver"/>
        </Style>
    </Window.Resources>

    <Grid>
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Top" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0" Height="48">
                <Grid Margin="20,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="Открыть файл .cfg" Command="{Binding OpenFileCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Button Content="Настройки" Command="{Binding OpenSettingsCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Button Content="Сбросить масштаб" Command="{Binding ResetZoomCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Button Content="Сброс диапазона" Command="{Binding ClearRangeCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusText}" Foreground="#2E7D32" FontWeight="SemiBold" Margin="0,0,20,0"/>
                        <TextBlock Text="{Binding FileInfo}" Foreground="#555" FontWeight="SemiBold" Margin="10,0,20,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollBar DockPanel.Dock="Bottom" 
                       Orientation="Horizontal"
                       Minimum="{Binding ScrollMinimum}"
                       Maximum="{Binding ScrollMaximum}"
                       Value="{Binding ScrollValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       ViewportSize="{Binding ViewportSize}"
                       SmallChange="0.01"
                       LargeChange="{Binding ViewportSize}"
                       Margin="10,0,10,5"/>

            <TabControl ItemsSource="{Binding OpenFiles}" SelectedItem="{Binding SelectedFile}">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="✕" 
                                    Style="{StaticResource TabCloseButtonStyle}"
                                    Command="{Binding DataContext.CloseFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding FilteredChannelPlots}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <views:ChannelPlotControl DataContext="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </DockPanel>

        <Border Background="#FDFFE0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4"
                Padding="12,8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="20"
                Visibility="{Binding HasRangeInfo, Converter={StaticResource BoolToVis}}">
            <Border.Effect>
                <DropShadowEffect Color="#AAA" BlurRadius="5" ShadowDepth="1" Opacity="0.25"/>
            </Border.Effect>
            <TextBlock Text="{Binding RangeInfoText}" FontWeight="Bold" LineHeight="14" Foreground="#333"/>
        </Border>
    </Grid>
</Window>
