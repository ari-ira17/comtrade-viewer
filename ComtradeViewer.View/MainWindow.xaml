<Window x:Class="ComtradeViewer.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ComtradeViewer.ViewModel.ViewModels;assembly=ComtradeViewer.ViewModel"
        xmlns:conv="clr-namespace:ComtradeViewer.View.Converters"
        Title="Comtrade Viewer" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:PointsToGeometryConverter x:Key="PointsToGeometryConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Открыть CFG..." Click="OpenButton_Click" Padding="10,5"/>
            <ComboBox Width="200" Margin="10,0"
                      ItemsSource="{Binding Channels}" 
                      SelectedItem="{Binding SelectedChannel}"/>
            <TextBlock Text="{Binding StatusText}" Margin="20,0,0,0" VerticalAlignment="Center" 
                       Foreground="DarkGreen" FontWeight="SemiBold"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Background="White">
            <Path Stroke="SteelBlue" StrokeThickness="1.5" Stretch="Fill" 
                  Data="{Binding ChartPoints, Converter={StaticResource PointsToGeometryConverter}}"/>
        </Border>

        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding FileInfo, FallbackValue='Файл не загружен'}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
