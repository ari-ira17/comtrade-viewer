<Window x:Class="ComtradeViewer.View.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ComtradeViewer.ViewModel.ViewModels;assembly=ComtradeViewer.ViewModel"
        xmlns:conv="clr-namespace:ComtradeViewer.View.Converters"
        Title="Comtrade Viewer" Height="450" Width="800">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:PointsToGeometryConverter x:Key="PointsToGeometryConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Content="Открыть файл" Click="OpenButton_Click" Padding="10,5"/>
            <ComboBox Width="200" Margin="10,0"
                      ItemsSource="{Binding Channels}" 
                      SelectedItem="{Binding SelectedChannel}"/>
        </StackPanel>

        <Path Grid.Row="1" Stroke="SteelBlue" StrokeThickness="1" Stretch="Fill" Margin="10">
            <Path.Data>
                <Binding Path="ChartPoints" Converter="{StaticResource PointsToGeometryConverter}"/>
            </Path.Data>
        </Path>
    </Grid>
</Window>
